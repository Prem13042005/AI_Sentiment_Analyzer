# Environment Configuration
ENV=development
LOG_LEVEL=INFO

# FastAPI Backend Config
BACKEND_PORT=8000
API_URL=http://localhost:8000

# Database Config
# Postgres format: postgresql://user:password@localhost:5432/sentiment_db
# Defaults to SQLite if postgresql is not available or connection fails
DATABASE_URL=sqlite:///./sentiment.db

# MLflow Config
MLFLOW_TRACKING_URI=./mlruns

# Model weights storage location
MODEL_DIR=./models
